{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/iamniketas/contora/shared/contracts/transcription-server-config.schema.json",
  "title": "Shared Local Transcription Server Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "activeBackend",
    "whisperTranscribeURL",
    "mlxTranscribeURL",
    "mlxModelID",
    "fasterWhisperModelName",
    "fasterWhisperDiarizationEnabled",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "activeBackend": {
      "type": "string",
      "enum": [
        "whisper_http",
        "mlx_openai_http",
        "faster_whisper_process"
      ]
    },
    "whisperTranscribeURL": {
      "type": "string",
      "format": "uri"
    },
    "mlxTranscribeURL": {
      "type": "string",
      "format": "uri"
    },
    "mlxModelID": {
      "type": "string",
      "minLength": 1
    },
    "fasterWhisperModelName": {
      "type": "string",
      "minLength": 1
    },
    "fasterWhisperDiarizationEnabled": {
      "type": "boolean"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
