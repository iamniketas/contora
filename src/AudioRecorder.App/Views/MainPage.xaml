<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="AudioRecorder.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AudioRecorder"
    xmlns:views="using:AudioRecorder.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ── Update available banner ────────────────────────────────  -->
            <InfoBar
                x:Name="UpdateAvailableBanner"
                Grid.Row="0"
                IsOpen="False"
                IsClosable="True"
                Severity="Informational"
                Title="Доступно обновление"
                Message="">
                <InfoBar.ActionButton>
                    <Button
                        x:Name="UpdateBannerInstallButton"
                        Content="Обновить"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnUpdateBannerInstallClicked" />
                </InfoBar.ActionButton>
            </InfoBar>

            <!--  ── Main content ─────────────────────────────────────────────  -->
            <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
<ColumnDefinition x:Name="SettingsColumn" Width="280" />
<ColumnDefinition Width="Auto" />
<ColumnDefinition Width="320" />
<ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
<Border
                x:Name="SettingsPanel"
                Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Settings" />
                            <Button
                                Grid.Column="1"
                                Click="OnOpenSettingsWindowClicked"
                                Padding="6,4"
                                ToolTipService.ToolTip="Open settings window">
                                <FontIcon Glyph="&#xE713;" FontSize="14" />
                            </Button>
                        </Grid>
<StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Recordings folder" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    x:Name="OutputFolderTextBox"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Text="..."
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button
                                    Grid.Column="1"
                                    Click="OnSelectFolderClicked"
                                    Content="..."
                                    Padding="8,4"
                                    ToolTipService.ToolTip="Select folder" />
                            </Grid>
                        </StackPanel>
<StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Text="Output (system audio)" />
                            <Border
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                MaxHeight="120">
                                <ListView
                                    x:Name="OutputSourcesListView"
                                    SelectionMode="None"
                                    ItemsSource="{x:Bind OutputSources, Mode=OneWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="4,2" />
                                            <Setter Property="MinHeight" Value="32" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="views:AudioSourceViewModel">
                                            <CheckBox
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                Checked="OnSourceSelectionChanged"
                                                Unchecked="OnSourceSelectionChanged"
                                                MaxWidth="220"
                                                ToolTipService.ToolTip="{x:Bind Source.Name}">
                                                <TextBlock
                                                    Text="{x:Bind Source.Name}"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxWidth="180" />
                                            </CheckBox>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </StackPanel>
<StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AccentTextFillColorSecondaryBrush}"
                                Text="Input (microphones)" />
                            <Border
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                MaxHeight="120">
                                <ListView
                                    x:Name="InputSourcesListView"
                                    SelectionMode="None"
                                    ItemsSource="{x:Bind InputSources, Mode=OneWay}">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="4,2" />
                                            <Setter Property="MinHeight" Value="32" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="views:AudioSourceViewModel">
                                            <CheckBox
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                Checked="OnSourceSelectionChanged"
                                                Unchecked="OnSourceSelectionChanged"
                                                MaxWidth="220"
                                                ToolTipService.ToolTip="{x:Bind Source.Name}">
                                                <TextBlock
                                                    Text="{x:Bind Source.Name}"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxWidth="180" />
                                            </CheckBox>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </StackPanel>
<StackPanel Spacing="8">
                            <TextBlock
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="Updates" />

                            <Button
                                x:Name="CheckUpdatesButton"
                                Click="OnCheckUpdatesClicked"
                                Content="Check for updates" />

                            <ProgressBar
                                x:Name="UpdateProgressBar"
                                Minimum="0"
                                Maximum="100"
                                Height="4"
                                Visibility="Collapsed" />

                            <TextBlock
                                x:Name="UpdateStatusText"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Status: not checked"
                                TextWrapping="Wrap" />

                            <Button
                                x:Name="ApplyUpdateButton"
                                Click="OnApplyUpdateClicked"
                                Content="Apply update"
                                Visibility="Collapsed"
                                Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
<ToggleButton
                x:Name="ToggleSettingsButton"
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="OnToggleSettingsClicked"
                Content="&lt;&lt;"
                ToolTipService.ToolTip="Collapse/expand settings"
                Width="24"
                Padding="0"
                Background="Transparent"
                BorderThickness="0" />
<Border
                Grid.Column="2"
                Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Contora" />
<Border
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                        <StackPanel Spacing="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,4" Text="Status:" />
                                <TextBlock x:Name="StateTextBlock" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" FontWeight="SemiBold" Text="Stopped" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,4" Text="Time:" />
                                <TextBlock x:Name="DurationTextBlock" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" Text="00:00:00" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" Text="Size:" />
                                <TextBlock x:Name="FileSizeTextBlock" Grid.Row="2" Grid.Column="1" Text="0 MB" />
                            </Grid>
                        </StackPanel>
                    </Border>
<TextBlock
                        x:Name="CurrentFileTextBlock"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text=""
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{x:Bind CurrentFileTextBlock.Text, Mode=OneWay}" />
<Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            x:Name="StartStopButton"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Click="OnStartStopClicked"
                            Content="Start recording"
                            IsEnabled="False"
                            Style="{StaticResource AccentButtonStyle}" />

                        <Button
                            x:Name="PauseResumeButton"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="OnPauseResumeClicked"
                            Content="Pause"
                            IsEnabled="False" />
                    </Grid>
<Button
                        x:Name="ImportButton"
                        HorizontalAlignment="Stretch"
                        Click="OnImportClicked"
                        Content="Import file" />
<Border
                        x:Name="TranscriptionControlSection"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Visibility="Visible">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="14" FontWeight="Medium" Text="Transcription" />
<StackPanel x:Name="TranscriptionProgressPanel" Spacing="8" Visibility="Collapsed">
                                <ProgressBar
                                    x:Name="TranscriptionProgressBar"
                                    Minimum="0"
                                    Maximum="100"
                                    IsIndeterminate="True"
                                    Height="4" />
<TextBlock
                                    x:Name="TranscriptionStatusText"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Preparing..." />
<Grid x:Name="TranscriptionDetailsGrid" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Elapsed:" FontSize="12" Margin="0,0,8,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="ElapsedTimeText" Grid.Row="0" Grid.Column="1" Text="--" FontSize="12" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Speed:" FontSize="12" Margin="0,0,8,4" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="SpeedText" Grid.Row="1" Grid.Column="1" Text="--" FontSize="12" Margin="0,0,0,4" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Remaining:" FontSize="12" Margin="0,0,8,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="RemainingTimeText" Grid.Row="2" Grid.Column="1" Text="--" FontSize="12" />
                                </Grid>
                            </StackPanel>
<StackPanel x:Name="TranscriptionStatsPanel" Spacing="4" Visibility="Collapsed">
                                <TextBlock Text="Statistics" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,4" />
                                <TextBlock x:Name="TranscriptionStatsText" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Mode:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox
                                    x:Name="TranscriptionModeComboBox"
                                    Grid.Column="1"
                                    SelectionChanged="OnTranscriptionModeChanged">
                                    <ComboBoxItem Content="Quality (best accuracy)" Tag="quality" />
                                    <ComboBoxItem Content="Light (faster)" Tag="light" />
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox
                                    x:Name="WhisperModelComboBox"
                                    Grid.Column="1"
                                    SelectionChanged="OnWhisperModelChanged" />
                            </Grid>
<Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8,6">
                                <TextBlock
                                    x:Name="DeviceInfoText"
                                    FontSize="12"
                                    Text="Device: Auto (GPU preferred)"
                                    TextWrapping="Wrap" />
                            </Border>
<Button
                                x:Name="TranscribeButton"
                                HorizontalAlignment="Stretch"
                                Click="OnTranscribeClicked"
                                Content="Transcribe" />
<InfoBar
                                x:Name="RuntimeOutdatedBar"
                                IsOpen="False"
                                Severity="Warning"
                                Title="Whisper runtime outdated"
                                Message="Update required for diarization support." />

                            <Button
                                x:Name="UpdateRuntimeButton"
                                HorizontalAlignment="Stretch"
                                Click="OnUpdateRuntimeClicked"
                                Content="Update runtime"
                                Visibility="Collapsed"
                                Style="{StaticResource AccentButtonStyle}" />

                            <InfoBar
                                x:Name="WhisperWarningBar"
                                IsOpen="False"
                                Severity="Warning"
                                Title="Whisper runtime is missing"
                                Message="Download faster-whisper-xxl to continue" />

                            <Button
                                x:Name="DownloadRuntimeButton"
                                HorizontalAlignment="Stretch"
                                Click="OnDownloadRuntimeClicked"
                                Content="Download Whisper XXL runtime"
                                Visibility="Collapsed" />

                            <Button
                                x:Name="CancelRuntimeDownloadButton"
                                HorizontalAlignment="Stretch"
                                Click="OnCancelRuntimeDownloadClicked"
                                Content="Cancel runtime download"
                                Visibility="Collapsed" />

                            <ProgressBar
                                x:Name="RuntimeDownloadProgressBar"
                                Minimum="0"
                                Maximum="100"
                                Height="4"
                                Visibility="Collapsed" />

                            <TextBlock
                                x:Name="RuntimeDownloadStatusText"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />

                            <Button
                                x:Name="DownloadModelButton"
                                HorizontalAlignment="Stretch"
                                Click="OnDownloadModelClicked"
                                Content="Download selected Whisper model"
                                Visibility="Collapsed" />

                            <Button
                                x:Name="CancelModelDownloadButton"
                                HorizontalAlignment="Stretch"
                                Click="OnCancelModelDownloadClicked"
                                Content="Cancel model download"
                                Visibility="Collapsed" />

                            <ProgressBar
                                x:Name="ModelDownloadProgressBar"
                                Minimum="0"
                                Maximum="100"
                                Height="4"
                                Visibility="Collapsed" />

                            <TextBlock
                                x:Name="ModelDownloadStatusText"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />

                            <InfoBar
                                x:Name="FfmpegWarningBar"
                                IsOpen="False"
                                Severity="Informational"
                                Title="FFmpeg is not installed"
                                Message="FFmpeg is needed for video import. Download ~140 MB." />

                            <Button
                                x:Name="DownloadFfmpegButton"
                                HorizontalAlignment="Stretch"
                                Click="OnDownloadFfmpegClicked"
                                Content="Download FFmpeg"
                                Visibility="Collapsed" />

                            <Button
                                x:Name="CancelFfmpegDownloadButton"
                                HorizontalAlignment="Stretch"
                                Click="OnCancelFfmpegDownloadClicked"
                                Content="Cancel FFmpeg download"
                                Visibility="Collapsed" />

                            <ProgressBar
                                x:Name="FfmpegDownloadProgressBar"
                                Minimum="0"
                                Maximum="100"
                                Height="4"
                                Visibility="Collapsed" />

                            <TextBlock
                                x:Name="FfmpegDownloadStatusText"
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
<Border
                Grid.Column="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0">
                <Pivot x:Name="RightPanelPivot" Padding="12,0,12,0">

                    <!--  ── Transcript tab ───────────────────────────────────  -->
                    <PivotItem Header="Transcript">
                        <Grid RowSpacing="12" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Current transcript"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button
                                    x:Name="CopyTranscriptButton"
                                    Grid.Column="1"
                                    Click="OnCopyTranscriptClicked"
                                    Visibility="Collapsed"
                                    Padding="8,4"
                                    Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Copy transcript">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                </Button>
                                <Button
                                    x:Name="SaveTranscriptionButton"
                                    Grid.Column="2"
                                    Click="OnSaveTranscriptionClicked"
                                    Visibility="Collapsed"
                                    Padding="8,4"
                                    Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Save changes">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse
                                            x:Name="SaveIndicator"
                                            Width="8"
                                            Height="8"
                                            Fill="#4CAF50"
                                            VerticalAlignment="Center" />
                                        <FontIcon
                                            Glyph="&#xE74E;"
                                            FontSize="14" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="ExportToOutlineButton"
                                    Grid.Column="3"
                                    Click="OnExportToOutlineClicked"
                                    Visibility="Collapsed"
                                    Padding="8,4"
                                    ToolTipService.ToolTip="Export to Outline">
                                    <FontIcon Glyph="&#xE898;" FontSize="14" />
                                </Button>
                            </Grid>

                            <StackPanel
                                x:Name="SpeakersPanel"
                                Grid.Row="1"
                                Spacing="8"
                                Visibility="Collapsed">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Speakers (double-click to edit)" />
                                <ItemsRepeater
                                    x:Name="SpeakersRepeater"
                                    ItemsSource="{x:Bind Speakers, Mode=OneWay}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="8" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="views:SpeakerViewModel">
                                            <Border
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="8,4">
                                                <TextBox
                                                    Text="{x:Bind Name, Mode=TwoWay}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="White"
                                                    FontSize="12"
                                                    MinWidth="80"
                                                    TextChanged="OnSpeakerNameChanged" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </StackPanel>

                            <ListView
                                x:Name="TranscriptionListView"
                                Grid.Row="2"
                                ItemsSource="{x:Bind TranscriptionSegments, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,2" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="views:TranscriptionSegmentViewModel">
                                        <Grid ColumnSpacing="12" Padding="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="60" />
                                                <ColumnDefinition Width="Auto" MinWidth="60" MaxWidth="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button
                                                Grid.Column="0"
                                                Content="{x:Bind TimestampDisplay}"
                                                Click="OnTimestampClicked"
                                                Tag="{x:Bind}"
                                                Padding="6,3"
                                                FontSize="11"
                                                FontFamily="Consolas"
                                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                VerticalAlignment="Top"
                                                HorizontalAlignment="Left"
                                                ToolTipService.ToolTip="Play segment (click)" />
                                            <Border
                                                Grid.Column="1"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                VerticalAlignment="Top"
                                                RightTapped="OnSpeakerRightTapped"
                                                Tag="{x:Bind}">
                                                <Border.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem
                                                            Text="Rename speaker"
                                                            Click="OnRenameSpeakerClicked"
                                                            Tag="{x:Bind}" />
                                                    </MenuFlyout>
                                                </Border.ContextFlyout>
                                                <TextBlock
                                                    Text="{x:Bind SpeakerName, Mode=OneWay}"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTipService.ToolTip="Right-click to rename" />
                                            </Border>
                                            <TextBox
                                                Grid.Column="2"
                                                Text="{x:Bind Text, Mode=TwoWay}"
                                                TextWrapping="Wrap"
                                                AcceptsReturn="False"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                FontSize="13"
                                                VerticalAlignment="Top"
                                                Padding="4,2"
                                                TextChanged="OnSegmentTextChanged"
                                                Tag="{x:Bind}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </PivotItem>

                    <!--  ── Analysis tab ─────────────────────────────────────  -->
                    <PivotItem Header="Analysis">
                        <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="16">

                                <!--  Empty hint  -->
                                <TextBlock
                                    x:Name="AnalysisEmptyHint"
                                    Text="Откройте сессию из вкладки Sessions, чтобы увидеть AI-анализ."
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="Wrap"
                                    Visibility="Visible" />

                                <!--  Summary section  -->
                                <StackPanel
                                    x:Name="AnalysisSummarySection"
                                    Spacing="6"
                                    Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Text="📝 Summary"
                                            VerticalAlignment="Center" />
                                        <Button
                                            x:Name="CopyAnalysisButton"
                                            Grid.Column="1"
                                            Click="OnCopyAnalysisClicked"
                                            Padding="8,4"
                                            ToolTipService.ToolTip="Copy full analysis">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                    <TextBlock
                                        x:Name="AnalysisSummaryText"
                                        FontSize="13"
                                        TextWrapping="Wrap"
                                        Text="" />
                                </StackPanel>

                                <!--  Action Items section  -->
                                <StackPanel
                                    x:Name="AnalysisActionItemsSection"
                                    Spacing="6"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Text="✅ Action Items" />
                                    <ItemsRepeater ItemsSource="{x:Bind AnalysisActionItems, Mode=OneWay}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="4" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox
                                                        Grid.Column="0"
                                                        IsEnabled="False"
                                                        VerticalAlignment="Top"
                                                        Margin="0,-4,0,0" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind}"
                                                        FontSize="13"
                                                        TextWrapping="Wrap"
                                                        VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>

                                <!--  Decisions section  -->
                                <StackPanel
                                    x:Name="AnalysisDecisionsSection"
                                    Spacing="6"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Text="🟢 Decisions" />
                                    <ItemsRepeater ItemsSource="{x:Bind AnalysisDecisions, Mode=OneWay}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="4" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="·" FontSize="13" VerticalAlignment="Top" Margin="0,1,0,0" />
                                                    <TextBlock
                                                        Text="{x:Bind}"
                                                        FontSize="13"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <!--  ── Sessions tab ──────────────────────────────────────  -->
                    <PivotItem Header="Sessions">
                        <Grid RowSpacing="8" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Search box  -->
                            <TextBox
                                x:Name="SessionSearchBox"
                                Grid.Row="0"
                                PlaceholderText="Search sessions..."
                                TextChanged="OnSessionSearchChanged" />

                            <!--  Filter bar  -->
                            <StackPanel
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="4">
                                <RadioButton
                                    x:Name="FilterAll"
                                    GroupName="SessionFilter"
                                    Content="All"
                                    IsChecked="True"
                                    Style="{StaticResource DefaultRadioButtonStyle}"
                                    Checked="OnSessionFilterChanged"
                                    Tag="" />
                                <RadioButton
                                    x:Name="FilterRecorded"
                                    GroupName="SessionFilter"
                                    Content="Recorded"
                                    Checked="OnSessionFilterChanged"
                                    Tag="Recorded" />
                                <RadioButton
                                    x:Name="FilterTranscribed"
                                    GroupName="SessionFilter"
                                    Content="Transcribed"
                                    Checked="OnSessionFilterChanged"
                                    Tag="Transcribed" />
                                <RadioButton
                                    x:Name="FilterExported"
                                    GroupName="SessionFilter"
                                    Content="Exported"
                                    Checked="OnSessionFilterChanged"
                                    Tag="Exported" />
                            </StackPanel>

                            <!--  Sessions list  -->
                            <ListView
                                x:Name="SessionsListView"
                                Grid.Row="2"
                                ItemsSource="{x:Bind Sessions, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,3" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="views:SessionViewModel">
                                        <Border
                                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12,10"
                                            PointerPressed="OnSessionItemPointerPressed"
                                            Tag="{x:Bind}">
                                            <Grid RowSpacing="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!--  Title + rename button + state badge  -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        Text="{x:Bind Title}"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <Button
                                                        Grid.Column="1"
                                                        Click="OnRenameButtonClicked"
                                                        Tag="{x:Bind}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Width="22"
                                                        Height="22"
                                                        Padding="0"
                                                        Margin="4,0,2,0"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.ToolTip="Rename">
                                                        <FontIcon
                                                            FontFamily="Segoe Fluent Icons"
                                                            Glyph="&#xE70F;"
                                                            FontSize="11" />
                                                    </Button>
                                                    <Border
                                                        Grid.Column="2"
                                                        Background="{x:Bind StateBrush}"
                                                        CornerRadius="3"
                                                        Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Margin="4,0,0,0">
                                                        <TextBlock
                                                            Text="{x:Bind StateLabel}"
                                                            FontSize="10"
                                                            Foreground="White" />
                                                    </Border>
                                                </Grid>

                                                <!--  Date + duration  -->
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Text="{x:Bind DateDurationDisplay}"
                                                    FontSize="11"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                                <!--  Preview text  -->
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Text="{x:Bind PreviewText}"
                                                    FontSize="11"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    TextTrimming="CharacterEllipsis"
                                                    MaxLines="2"
                                                    TextWrapping="Wrap" />

                                                <!--  Publish to Outline (visible when transcribed but not yet published)  -->
                                                <Button
                                                    Grid.Row="3"
                                                    Tag="{x:Bind}"
                                                    Visibility="{x:Bind PublishButtonVisibility}"
                                                    Click="OnPublishSessionToOutlineClicked"
                                                    FontSize="11"
                                                    Padding="6,3"
                                                    HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <FontIcon Glyph="&#xE8A1;" FontSize="11" />
                                                        <TextBlock Text="Publish to Outline" FontSize="11" />
                                                    </StackPanel>
                                                </Button>

                                                <!--  Outline link (visible only when published)  -->
                                                <HyperlinkButton
                                                    Grid.Row="4"
                                                    Tag="{x:Bind OutlineDocumentUrl}"
                                                    Visibility="{x:Bind OutlineUrlVisibility}"
                                                    Click="OnOutlineLinkClicked"
                                                    Content="Open in Outline"
                                                    FontSize="11"
                                                    Padding="0,2,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!--  Load more  -->
                            <Button
                                x:Name="LoadMoreButton"
                                Grid.Row="3"
                                HorizontalAlignment="Stretch"
                                Margin="0,4,0,0"
                                Padding="0,8"
                                Visibility="Collapsed"
                                Click="OnLoadMoreClicked">
                                <TextBlock
                                    x:Name="LoadMoreText"
                                    Text="Load more"
                                    FontSize="12" />
                            </Button>

                        </Grid>
                    </PivotItem>

                </Pivot>
            </Border>
            </Grid>
        </Grid>
    </Page.Content>
</Page>


